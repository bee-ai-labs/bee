{
  "version": "0.2",
  "language": "en",
  "dictionaries": ["en_US", "python", "softwareTerms", "bee-terms"],
  "dictionaryDefinitions": [
    {
      "name": "bee-terms",
      "path": "./.cspell-dict.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules/**",
    "site/**",
    ".venv/**",
    "*.svg",
    "CHANGELOG.md",
    "**/pyproject.toml",
    ".git/**"
  ],
  "ignoreRegExpList": ["/`{1,3}[^`]*`{1,3}/", "/\\]\\([^)]*\\)/", "/https?:\\/\\/\\S+/"]
}
