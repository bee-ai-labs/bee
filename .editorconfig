# EditorConfig — https://editorconfig.org
# Keeps formatting consistent across every editor and contributor.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 88

[*.md]
# Trailing whitespace can be meaningful in Markdown (hard line breaks).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml,json,toml}]
indent_size = 2
